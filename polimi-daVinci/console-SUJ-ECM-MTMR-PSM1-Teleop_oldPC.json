{
    "io": {
        "footpedals": "io/sawRobotIO1394-MTMR-foot-pedals.xml"
        , "watchdog-timeout": 0.04 // in seconds
        , "firewire-protocol": "broadcast-read-write"
    }
    ,
    "operator-present": {
        "io": "io/sawRobotIO1394-MTML-dv-head-sensor.xml"
    }
    ,
